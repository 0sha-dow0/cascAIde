# cascAIde configuration template.
# Copy to backend/.env for local runs, or set these as env vars on your host.
# NEVER commit real values — backend/.env is git-ignored.

# false = use live integrations (Butterbase, Neo4j, Groq, Cognee).
DEPCOVER_USE_FAKES=false
DEPCOVER_JUDGES_DEGRADED=false

# Split hosting (UI on Butterbase, this API on Render): allow the UI's origin so the
# browser can call this API cross-origin. Comma-separated. Leave empty for all-in-one.
DEPCOVER_CORS_ORIGINS=https://cascaide.butterbase.dev
# (Frontend side, set at BUILD time, not here: VITE_API_BASE=https://YOUR-BACKEND.onrender.com)

# --- LLM secrets (adapters read these by the *_API_KEY_ENV names below) ---
GROQ_API_KEY=REPLACE_WITH_GROQ_KEY
OPENROUTER_API_KEY=REPLACE_WITH_OPENROUTER_KEY

# --- Daytona sandbox (REQUIRED — runs `node --check` on the rewrite in a real, network-blocked
#     node:20-alpine box, so a transplant only ships if it actually compiles). Keep it ON. ---
DEPCOVER_USE_DAYTONA=true
DAYTONA_API_KEY=REPLACE_WITH_DAYTONA_KEY
DEPCOVER_DAYTONA_API_URL=https://app.daytona.io/api
DEPCOVER_DAYTONA_SNAPSHOT_ID=node-20-alpine
DEPCOVER_SANDBOX_EXEC_TIMEOUT_S=120
DEPCOVER_SANDBOX_ACQUIRE_TIMEOUT_S=30

# --- Neo4j (Aura free tier or self-hosted) — powers the dependency/blast-radius graph ---
DEPCOVER_NEO4J_URI=neo4j+s://YOUR-INSTANCE.databases.neo4j.io
DEPCOVER_NEO4J_USER=neo4j
DEPCOVER_NEO4J_PASSWORD_ENV=NEO4J_PASSWORD
NEO4J_PASSWORD=REPLACE_WITH_NEO4J_PASSWORD

# --- Butterbase (GitHub sign-in + acts on GitHub as the user for PRs/issues) ---
DEPCOVER_BUTTERBASE_BASE_URL=https://api.butterbase.ai
DEPCOVER_BUTTERBASE_APP_ID=app_YOUR_APP_ID
DEPCOVER_BUTTERBASE_KEY_ENV=BUTTERBASE_KEY
BUTTERBASE_KEY=REPLACE_WITH_BUTTERBASE_SERVICE_KEY

# --- GitHub (optional PAT for polling; the user flow uses Butterbase, not this) ---
DEPCOVER_GITHUB_TOKEN_ENV=GITHUB_TOKEN
GITHUB_TOKEN=REPLACE_OR_LEAVE
DEPCOVER_GITHUB_POLL_INTERVAL_S=10

# --- Cognee Cloud (code memory for the "Explore" implementation plans) ---
DEPCOVER_COGNEE_BASE_URL=https://YOUR-TENANT.aws.cognee.ai
DEPCOVER_COGNEE_API_KEY_ENV=COGNEE_API_KEY
COGNEE_API_KEY=REPLACE_WITH_COGNEE_KEY

# ===================== LLM role allocation =====================
# Each role points at an OpenAI-compatible endpoint. *_API_KEY_ENV names the env var
# holding that role's secret (so no raw keys are stored in Settings). Groq is the default.

# TRANSPLANT — the coder that rewrites call sites
DEPCOVER_LLM_TRANSPLANT_BASE_URL=https://api.groq.com/openai/v1
DEPCOVER_LLM_TRANSPLANT_MODEL=meta-llama/llama-4-scout-17b-16e-instruct
DEPCOVER_LLM_TRANSPLANT_API_KEY_ENV=GROQ_API_KEY
DEPCOVER_LLM_TRANSPLANT_MAX_TOKENS=5000
DEPCOVER_LLM_TRANSPLANT_TIMEOUT_S=120

# JUDGE A — Correctness
DEPCOVER_LLM_JUDGE_CORRECTNESS_BASE_URL=https://api.groq.com/openai/v1
DEPCOVER_LLM_JUDGE_CORRECTNESS_MODEL=openai/gpt-oss-120b
DEPCOVER_LLM_JUDGE_CORRECTNESS_API_KEY_ENV=GROQ_API_KEY
DEPCOVER_LLM_JUDGE_CORRECTNESS_MAX_TOKENS=1024
DEPCOVER_LLM_JUDGE_CORRECTNESS_TIMEOUT_S=60

# JUDGE B — Security
DEPCOVER_LLM_JUDGE_SECURITY_BASE_URL=https://api.groq.com/openai/v1
DEPCOVER_LLM_JUDGE_SECURITY_MODEL=openai/gpt-oss-120b
DEPCOVER_LLM_JUDGE_SECURITY_API_KEY_ENV=GROQ_API_KEY
DEPCOVER_LLM_JUDGE_SECURITY_MAX_TOKENS=1024
DEPCOVER_LLM_JUDGE_SECURITY_TIMEOUT_S=60

# JUDGE C — Minimality
DEPCOVER_LLM_JUDGE_MINIMALITY_BASE_URL=https://api.groq.com/openai/v1
DEPCOVER_LLM_JUDGE_MINIMALITY_MODEL=meta-llama/llama-4-scout-17b-16e-instruct
DEPCOVER_LLM_JUDGE_MINIMALITY_API_KEY_ENV=GROQ_API_KEY
DEPCOVER_LLM_JUDGE_MINIMALITY_MAX_TOKENS=1024
DEPCOVER_LLM_JUDGE_MINIMALITY_TIMEOUT_S=90

# JUDGE D — Recipe fidelity
DEPCOVER_LLM_JUDGE_RECIPE_BASE_URL=https://api.groq.com/openai/v1
DEPCOVER_LLM_JUDGE_RECIPE_MODEL=llama-3.1-8b-instant
DEPCOVER_LLM_JUDGE_RECIPE_API_KEY_ENV=GROQ_API_KEY
DEPCOVER_LLM_JUDGE_RECIPE_MAX_TOKENS=1024
DEPCOVER_LLM_JUDGE_RECIPE_TIMEOUT_S=90

# MITIGATION — the ranked strategy cards
DEPCOVER_LLM_MITIGATION_BASE_URL=https://api.groq.com/openai/v1
DEPCOVER_LLM_MITIGATION_MODEL=llama-3.3-70b-versatile
DEPCOVER_LLM_MITIGATION_API_KEY_ENV=GROQ_API_KEY
DEPCOVER_LLM_MITIGATION_MAX_TOKENS=2048
DEPCOVER_LLM_MITIGATION_TIMEOUT_S=60

# PR_SCREEN — PR gate screening
DEPCOVER_LLM_PR_SCREEN_BASE_URL=https://api.groq.com/openai/v1
DEPCOVER_LLM_PR_SCREEN_MODEL=llama-3.1-8b-instant
DEPCOVER_LLM_PR_SCREEN_API_KEY_ENV=GROQ_API_KEY
DEPCOVER_LLM_PR_SCREEN_MAX_TOKENS=1024
DEPCOVER_LLM_PR_SCREEN_TIMEOUT_S=60

# EXPLORE — code-memory-grounded implementation plans
DEPCOVER_LLM_EXPLORE_BASE_URL=https://api.groq.com/openai/v1
DEPCOVER_LLM_EXPLORE_MODEL=llama-3.3-70b-versatile
DEPCOVER_LLM_EXPLORE_API_KEY_ENV=GROQ_API_KEY
DEPCOVER_LLM_EXPLORE_MAX_TOKENS=2048
DEPCOVER_LLM_EXPLORE_TIMEOUT_S=90
